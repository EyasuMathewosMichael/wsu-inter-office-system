<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.DropShadow?>

<HBox spacing="20" style="-fx-background-color: #f8fafc;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.frontenddesktop.controller.ChatController">

    <padding><Insets top="20" right="25" bottom="25" left="25"/></padding>

    <VBox prefWidth="280" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;">
        <effect><DropShadow blurType="GAUSSIAN" color="#00000008" height="20" radius="9.5" width="20"/></effect>

        <Label text="Messages" style="-fx-font-weight: 900; -fx-font-size: 18px; -fx-text-fill: #1e293b;"/>

        <StackPane alignment="CENTER_RIGHT">
            <TextField fx:id="searchField" promptText="🔍 Search staff..."
                       style="-fx-background-radius: 10; -fx-background-color: #f1f5f9; -fx-padding: 10 35 10 12; -fx-border-color: #e2e8f0; -fx-border-radius: 10;"/>
            <Button fx:id="btnClearSearch" text="✕" onAction="#handleClearSearch" visible="false"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-font-size: 12px;">
                <StackPane.margin><Insets right="8"/></StackPane.margin>
            </Button>
        </StackPane>

        <ListView fx:id="channelList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0; -fx-border-color: transparent;"/>
    </VBox>

    <VBox spacing="15" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 10 0;">
            <VBox spacing="2">
                <Label fx:id="lblChatHeader" text="Department Chat"
                       style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
                <Label fx:id="lblDeptHeader" text="General Discussion"
                       style="-fx-font-size: 13px; -fx-text-fill: #3b82f6; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Circle fx:id="statusCircle" radius="6" fill="#2ecc71" /> </HBox>

        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER"
                    styleClass="scroll-pane"
                    style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15;">
            <effect><DropShadow blurType="GAUSSIAN" color="#00000005" height="15" radius="7" width="15"/></effect>
            <VBox fx:id="chatBox" spacing="20" style="-fx-padding: 20;"/>
        </ScrollPane>

        <VBox spacing="0">
            <HBox fx:id="replyPreviewBar" visible="false" managed="false" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f8fafc; -fx-padding: 10 15; -fx-background-radius: 12 12 0 0; -fx-border-color: #3b82f6; -fx-border-width: 0 0 0 4;">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Replying to" style="-fx-font-size: 11px; -fx-text-fill: #3b82f6; -fx-font-weight: bold;"/>
                    <Label fx:id="lblReplyText" text="..." style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-style: italic;" wrapText="false"/>
                </VBox>
                <Button text="✕" onAction="#cancelReply"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <HBox fx:id="attachmentBar" visible="false" managed="false" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f1f5f9; -fx-padding: 8 15; -fx-background-radius: 10;">
                <Label text="📎" style="-fx-font-size: 14px;"/>
                <Label fx:id="lblFileName" text="file_name.pdf" style="-fx-font-size: 12px; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#handleClearAttachment"
                        style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                <Button text="📎" onAction="#handleAttachFile"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #64748b; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48; -fx-font-size: 18px; -fx-cursor: hand; -fx-border-color: #e2e8f0; -fx-border-radius: 12;"/>

                <TextField fx:id="messageField" promptText="Type a message..." HBox.hgrow="ALWAYS"
                           onAction="#handleSendMessage"
                           style="-fx-background-radius: 12; -fx-padding: 14 15; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-background-color: white; -fx-font-size: 14px;">
                    <effect><DropShadow blurType="GAUSSIAN" color="#00000005" height="10" radius="4.5" width="10"/></effect>
                </TextField>

                <Button fx:id="btnSend" text="Send" onAction="#handleSendMessage"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 25; -fx-font-weight: bold; -fx-cursor: hand; -fx-min-height: 48;">
                    <effect><DropShadow blurType="GAUSSIAN" color="#3b82f644" height="15" radius="7" width="15"/></effect>
                </Button>
            </HBox>
        </VBox>
    </VBox>
</HBox>
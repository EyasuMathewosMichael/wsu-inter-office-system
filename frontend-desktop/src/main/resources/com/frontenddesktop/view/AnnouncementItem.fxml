<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootNode" spacing="8" maxWidth="Infinity"
      style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8, 0, 0, 3);"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.frontenddesktop.controller.AnnouncementItemController">

    <padding><Insets top="15" right="18" bottom="15" left="18"/></padding>

    <HBox spacing="5" alignment="CENTER_LEFT">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="SENDER:" style="-fx-text-fill: #94a3b8; -fx-font-size: 9px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
            <Label fx:id="lblSender" text="Name (Role)"
                   style="-fx-text-fill: #3b82f6; -fx-font-size: 11px; -fx-font-weight: bold;"/>
        </VBox>

        <HBox fx:id="adminControls" spacing="8" visible="false" managed="${adminControls.visible}">
            <Button onAction="#handleEdit"
                    style="-fx-background-color: #f1f5f9; -fx-background-radius: 5; -fx-cursor: hand; -fx-min-width: 32; -fx-min-height: 32;">
                <graphic>
                    <Label text="EDIT" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                </graphic>
                <tooltip><Tooltip text="Edit Announcement"/></tooltip>
            </Button>
            <Button onAction="#handleDelete"
                    style="-fx-background-color: #fef2f2; -fx-background-radius: 5; -fx-cursor: hand; -fx-min-width: 32; -fx-min-height: 32;">
                <graphic>
                    <Label text="DEL" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
                </graphic>
                <tooltip><Tooltip text="Delete Announcement"/></tooltip>
            </Button>
        </HBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label fx:id="lblTitle" text="Announcement Title"
               style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"
               HBox.hgrow="ALWAYS" maxWidth="Infinity" wrapText="true"/>

        <Button fx:id="btnDownload" onAction="#handleDownload"
                style="-fx-background-color: #f1f5f9; -fx-background-radius: 50; -fx-cursor: hand; -fx-min-width: 30; -fx-min-height: 30;"
                visible="false" managed="${btnDownload.visible}">
            <graphic>
                <Label text="FILE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
            </graphic>
            <tooltip><Tooltip text="View Reels/Docs"/></tooltip>
        </Button>
    </HBox>

    <Label fx:id="lblContent" text="Details of the faith campaign..."
           wrapText="true" VBox.vgrow="ALWAYS" maxWidth="Infinity"
           style="-fx-text-fill: #334155; -fx-font-size: 14px; -fx-line-spacing: 1.5;"/>

    <HBox spacing="10" alignment="BOTTOM_LEFT" maxWidth="Infinity">
        <Button fx:id="btnViewMore" text="Read Full Story →" onAction="#handleViewFullAnnouncement"
                style="-fx-background-color: transparent; -fx-text-fill: #2563eb; -fx-padding: 0; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 12px;"
                visible="false" managed="${btnViewMore.visible}"/>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="6" style="-fx-opacity: 0.7;">
            <Label text="📅" style="-fx-font-size: 11px;"/>
            <Label fx:id="lblDate" text="Feb 24, 2026" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
        </HBox>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.frontenddesktop.controller.LoginController"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="20.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="5">
        <Text text="Welcome Back"
              style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #1e293b;"/>
        <Text text="Inter-Office Communication System"
              style="-fx-fill: #64748b; -fx-font-size: 13px;"/>
    </VBox>

    <VBox spacing="8.0" maxWidth="320">
        <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <TextField fx:id="usernameField" promptText="Enter your username"
                   style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-color: #f8fafc;"/>
    </VBox>

    <VBox spacing="8.0" maxWidth="320">
        <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
        <HBox alignment="CENTER_LEFT"
              style="-fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: #f8fafc;">
            <StackPane HBox.hgrow="ALWAYS">
                <PasswordField fx:id="passwordField" promptText="Enter password"
                               style="-fx-padding: 12; -fx-background-color: transparent;"/>
                <TextField fx:id="passwordTextField" promptText="Enter password" visible="false"
                           style="-fx-padding: 12; -fx-background-color: transparent;"/>
            </StackPane>
            <Button fx:id="showPasswordButton" text="Show" onAction="#togglePasswordVisibility"
                    style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin" maxWidth="320"
            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;
                   -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;">
        <effect>
            <DropShadow blurType="GAUSSIAN" color="#3b82f644" height="10" radius="4.5" width="10"/>
        </effect>
    </Button>

    <Hyperlink text="Forgot Password?" onAction="#handleForgotPassword"
               style="-fx-text-fill: #64748b; -fx-underline: false; -fx-font-size: 13px;"/>

</VBox>

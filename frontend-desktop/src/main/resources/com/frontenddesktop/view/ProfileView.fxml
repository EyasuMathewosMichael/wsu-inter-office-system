<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f8fafc; -fx-background: #f8fafc;"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.frontenddesktop.controller.ProfileController">

    <content>
        <VBox spacing="35" alignment="TOP_CENTER">
            <padding><Insets top="40" right="50" bottom="60" left="50"/></padding>

            <VBox alignment="CENTER" spacing="15">
                <StackPane>
                    <Circle radius="62" fill="transparent" stroke="#3b82f6" strokeWidth="2" strokeDashArray="10, 5"/>
                    <Circle radius="55" fill="#3b82f6"/>
                    <ImageView fx:id="imgProfileAvatar" fitWidth="110" fitHeight="110" preserveRatio="false" visible="false"/>
                    <Text fx:id="txtAvatarInitials" text="??" style="-fx-font-size: 40px; -fx-fill: white; -fx-font-weight: bold;"/>
                    <effect>
                        <DropShadow blurType="GAUSSIAN" color="#3b82f633" height="30" radius="14.5" width="30"/>
                    </effect>
                </StackPane>

                <HBox alignment="CENTER" spacing="12">
                    <Button fx:id="btnChoosePhoto" text="Choose Photo" onAction="#handleChoosePhoto"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10 18;"/>
                    <Button fx:id="btnUploadPhoto" text="Upload Photo" onAction="#handleUploadPhoto" disable="true"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10 18;"/>
                </HBox>

                <Label fx:id="lblPhotoStatus" text="Your current profile photo will appear across the desktop app." wrapText="true"
                       style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: 500;"/>

                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="lblFullName" text="User Full Name" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
                    <HBox alignment="CENTER" spacing="10">
                        <Label fx:id="lblUserRole" text="ROLE" style="-fx-background-color: #dbeafe; -fx-text-fill: #1e40af; -fx-font-weight: bold; -fx-font-size: 11px; -fx-padding: 4 12; -fx-background-radius: 20;"/>
                        <Label fx:id="txtDeptDisplay" text="Department Name" style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    </HBox>
                </VBox>
            </VBox>

            <HBox spacing="30" alignment="CENTER">
                <VBox spacing="25" prefWidth="480" style="-fx-background-color: white; -fx-padding: 35; -fx-background-radius: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 20;">
                    <effect><DropShadow blurType="GAUSSIAN" color="#00000005" height="40" radius="19.5" width="40"/></effect>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Text text="Info" style="-fx-font-size: 18px;"/><Label text="Account Information" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
                    </HBox>
                    <VBox spacing="18">
                        <VBox spacing="6">
                            <Label text="Employee ID" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtId" editable="false" prefHeight="45" style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-text-fill: #64748b; -fx-font-family: 'Consolas';"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Primary Department" style="-fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtDept" editable="false" prefHeight="45" style="-fx-background-color: #f8fafc; -fx-background-radius: 10; -fx-text-fill: #64748b;"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Personal Email" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtEmail" promptText="Enter personal email for password reset" prefHeight="45" style="-fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-background-color: white;"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Phone Number" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextField fx:id="txtPhone" promptText="Enter phone number" prefHeight="45" style="-fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-background-color: white;"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Bio" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <TextArea fx:id="txtBio" promptText="Write a short bio" prefHeight="120" wrapText="true" style="-fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-background-color: white;"/>
                        </VBox>
                        <Button fx:id="btnSaveProfile" text="Save Profile Details" onAction="#handleSaveProfile" maxWidth="Infinity" prefHeight="48"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>

                <VBox spacing="25" prefWidth="480" style="-fx-background-color: white; -fx-padding: 35; -fx-background-radius: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 20;">
                    <effect><DropShadow blurType="GAUSSIAN" color="#00000005" height="40" radius="19.5" width="40"/></effect>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Text text="Lock" style="-fx-font-size: 18px;"/><Label text="Security &amp; Password" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
                    </HBox>
                    <VBox spacing="20">
                        <VBox spacing="8">
                            <Label text="Current Password" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <PasswordField fx:id="fieldCurrentPass" promptText="Confirm identity" prefHeight="45" style="-fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-background-color: white;"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="New Password" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <PasswordField fx:id="fieldNewPass" promptText="Enter strong password" prefHeight="45" style="-fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-background-color: white;"/>
                        </VBox>
                        <VBox spacing="8">
                            <Label text="Verify New Password" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            <PasswordField fx:id="fieldConfirmPass" promptText="Repeat new password" prefHeight="45" style="-fx-background-radius: 10; -fx-border-color: #cbd5e1; -fx-background-color: white;"/>
                        </VBox>
                        <Button fx:id="btnUpdate" text="Update Security Settings" onAction="#handleUpdatePassword" maxWidth="Infinity" prefHeight="48"
                                style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;">
                            <VBox.margin><Insets top="10"/></VBox.margin>
                        </Button>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
